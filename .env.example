# SihaVPN — пример конфигурации. Скопируйте в .env и заполните значения.
# Все секреты после первого запуска можно менять через админ-панель.

# ──────────── Админ-панель ────────────
ADMIN_PASSWORD=change_me
ADMIN_SECRET=change_me_to_a_long_random_string

# ──────────── Телеграм-бот ────────────
BOT_TOKEN=
BOT_USERNAME=SihaVPN_bot
CHANNEL_ID=
PROXY_URL=

# ──────────── База данных PostgreSQL ────────────
DB_USER=siha_user
DB_PASS=
DB_NAME=sihavpn
DB_HOST=127.0.0.1
DB_PORT=5432
DB_POOL_MIN=2
DB_POOL_MAX=10

# ──────────── Веб-сервер ────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
CABINET_BASE_URL=https://sihavpn.site
FALLBACK_CABINET_URL=https://backup.sihavpn.ru/cabinet

# ──────────── Ссылки в боте ────────────
CHANNEL_URL=https://t.me/SihaVPN_news
SUPPORT_URL=https://t.me/SihaSupport

# ──────────── Тарифы и бонусы ────────────
PRICE_PER_DEVICE=3.33
BONUS_SUBSCRIBE=25
BONUS_PHONE=95
BONUS_PHONE_SUB=5

# ──────────── VPN-серверы (используются при первой миграции) ────────────
# После переноса в БД управляются через админ-панель.
SERVER_COUNT=0
# SERVER1_NAME=Amsterdam-VDSina
# SERVER1_SCHEME=https
# SERVER1_HOST=example.com
# SERVER1_PORT=2053
# SERVER1_BASE_PATH=path_without_slashes
# SERVER1_LOGIN=admin
# SERVER1_PASSWORD=
# SERVER1_API_TOKEN=

# ──────────── Bypass IP / домены (необязательно) ────────────
# Подставляются вместо хоста сервера в inbound'ах с пометкой "| BYPASS".
# После первого старта список переносится в БД и редактируется через панель.
BYPASS_IPS=

# ──────────── Логирование ────────────
LOG_LEVEL=INFO
